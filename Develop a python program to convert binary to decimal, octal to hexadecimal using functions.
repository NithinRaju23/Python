def binary_to_decimal(binary_str):
    try:
        decimal = int(binary_str, 2)
        return decimal
    except ValueError:
        return "❌ Invalid binary number!"

# Function to convert octal to hexadecimal
def octal_to_hexadecimal(octal_str):
    try:
        decimal = int(octal_str, 8)
        hexadecimal = hex(decimal)[2:].upper()  # convert to hex & remove '0x'
        return hexadecimal
    except ValueError:
        return "X Invalid octal number!"


print("=== Number Conversion Menu ===")
print("1. Binary to Decimal")
print("2. Octal to Hexadecimal")

choice = input("Enter your choice (1 or 2): ")

if choice == '1':
    binary_input = input("Enter a binary number: ")
    result = binary_to_decimal(binary_input)
    print(f"\nDecimal value: {result}")

elif choice == '2':
    octal_input = input("Enter an octal number: ")
    result = octal_to_hexadecimal(octal_input)
    print(f"\nHexadecimal value: {result}")

else:
    print("X Invalid choice! Please select 1 or 2.")
